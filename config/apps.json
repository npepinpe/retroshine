{
    "env": {
        "PATH": "$(PATH):$(HOME)/.local/bin"
    },
    "apps": [
        {
            "auto-detach": true,
            "cmd": "emulationstation --home /config/es-de",
            "elevated": false,
            "exclude-global-prep-cmd": false,
            "exit-timeout": 5,
            "image-path": "",
            "name": "Emulation Station",
            "output": "",
            "wait-all": true
        },
        {
            "auto-detach": true,
            "cmd": "dusklight -screen-width 1920 -screen-height 1080 -screen-fullscreen 1",
            "elevated": false,
            "exclude-global-prep-cmd": false,
            "exit-timeout": 5,
            "image-path": "/root/.config/sunshine/covers/igdb_401002.png",
            "name": "Dusklight",
            "output": "/config/logs/dusklight.log",
            "wait-all": true
        }
    ]
}
