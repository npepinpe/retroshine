{
    "env": {
        "PATH": "$(PATH):$(HOME)/.local/bin"
    },
    "apps": [
        {
            "auto-detach": true,
            "cmd": "emulationstation",
            "elevated": false,
            "exclude-global-prep-cmd": false,
            "exit-timeout": 5,
            "image-path": "/root/.config/sunshine/covers/igdb_386308.png",
            "name": "Emulation Station",
            "output": "",
            "wait-all": true
        },
        {
            "auto-detach": true,
            "cmd": "dusklight",
            "elevated": false,
            "exclude-global-prep-cmd": false,
            "exit-timeout": 5,
            "image-path": "/root/.config/sunshine/covers/igdb_401002.png",
            "name": "Dusklight",
            "output": "",
            "wait-all": true
        }
    ]
}
